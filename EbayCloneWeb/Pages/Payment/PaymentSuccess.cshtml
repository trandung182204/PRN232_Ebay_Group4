@page
@model EbayWeb.Pages.Payment.PaymentSuccess
@{
    ViewData["Title"] = "Order Success";
}

<div class="container mt-5 text-center">
    <h2 class="text-success">🎉 Payment Successful</h2>

    <p class="mt-3 fs-5">
        @Model.Message
