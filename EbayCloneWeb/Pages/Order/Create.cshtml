@page
@model EbayCloneWeb.Pages.Order.CreateModel
@{
    ViewData["Title"] = "Buy — " + (Model.Product?.Title ?? "Product");
}

<div class="container-fluid px-4 py-3" style="max-width:1400px;margin:0 auto;">

    <!-- Breadcrumb -->
    <nav class="eb-breadcrumb">
        <a asp-page="/Index">Home</a>
        <span class="sep">›</span>
        <a asp-page="/Index">All listings</a>
        <span class="sep">›</span>
        <span>@Model.Product?.Title</span>
    </nav>

    <div class="row g-4">

        <!-- LEFT: Images -->
        <div class="col-lg-5">
            <div class="eb-product-card p-3">
                @if (Model.ImagesList != null && Model.ImagesList.Count > 0)
                {
                    <div id="productCarousel" class="carousel slide" data-bs-ride="false">
                        <div class="carousel-inner rounded-3 overflow-hidden border" style="background:#fff;min-height:340px;">
                            @for (int i = 0; i < Model.ImagesList.Count; i++)
                            {
                                var css = i == 0 ? "carousel-item active" : "carousel-item";
                                <div class="@css">
                                    <img src="@Model.ImagesList[i]"
                                         class="d-block mx-auto"
                                         style="object-fit:contain;height:360px;max-width:100%;" />
                                </div>
                            }
                        </div>
                        @if (Model.ImagesList.Count > 1)
                        {
                            <button class="carousel-control-prev" type="button" data-bs-target="#productCarousel" data-bs-slide="prev">
                                <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                                <span class="visually-hidden">Previous</span>
                            </button>
                            <button class="carousel-control-next" type="button" data-bs-target="#productCarousel" data-bs-slide="next">
                                <span class="carousel-control-next-icon" aria-hidden="true"></span>
                                <span class="visually-hidden">Next</span>
                            </button>
                        }
                    </div>
                    <div class="eb-thumb-strip">
                        @foreach (var img in Model.ImagesList)
                        {
                            <img src="@img" class="eb-thumb thumb-img" data-src="@img" alt="thumbnail" />
                        }
                    </div>
                }
                else
                {
                    <div class="text-center py-4 text-muted">
                        <i class="bi bi-image" style="font-size:4rem;opacity:.3"></i>
                        <p class="mt-2 small">No image available</p>
                    </div>
                }
            </div>
        </div>

        <!-- MIDDLE: Product info + order form -->
        <div class="col-lg-4">
            <div class="eb-product-card">

                <!-- Title & condition -->
                <div class="eb-product-title">@Model.Product?.Title</div>
                <div class="eb-product-condition">
                    Condition: <strong>New</strong>
                </div>

                <!-- Price -->
                <div class="eb-product-price">
                    US $@string.Format("{0:0.00}", Model.Product?.Price ?? 0)
                </div>
                <div class="eb-product-price-sub">Approximately listed price. Free returns.</div>

                <!-- Stock & rating -->
                <div class="d-flex align-items-center flex-wrap gap-2 mb-3">
                    <span class="eb-stock-badge">
                        <i class="bi bi-check-circle-fill"></i> In stock
                    </span>
                    <span class="eb-rating-badge">
                        <i class="bi bi-star-fill"></i>
                        @Model.AvgRating.ToString("0.0") / 5.0
                    </span>
                </div>

                <!-- Description -->
                @if (!string.IsNullOrWhiteSpace(Model.Product?.Description))
                {
                    <p class="text-muted small mb-3" style="line-height:1.6">@Model.Product.Description</p>
                }

                <!-- Order form -->
                <div class="eb-form-section">
                    <form method="post">
                        <input type="hidden" asp-for="ProductId" />

                        <div class="row g-3 mb-3">
                            <div class="col-5">
                                <label class="eb-form-label">Quantity</label>
                                <input asp-for="Quantity" class="form-control eb-form-control" min="1" type="number" />
                            </div>
                            <div class="col-7">
                                <label class="eb-form-label">Region</label>
                                <select asp-for="Region" class="form-select eb-form-control">
                                    <option value="north">North</option>
                                    <option value="central">Central</option>
                                    <option value="south">South</option>
                                </select>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="eb-form-label">Shipping address</label>
                            <textarea asp-for="Address" class="form-control eb-form-control" rows="3"
                                      placeholder="Enter full shipping address"></textarea>
                        </div>

                        <div class="mb-4">
                            <label class="eb-form-label">Payment method</label>
                            <select asp-for="PaymentMethod" class="form-select eb-form-control">
                                <option value="PAYPAL">PayPal</option>
                                <option value="COD">COD</option>
                            </select>
                        </div>

                        <button type="submit" class="eb-btn-order">
                            <i class="bi bi-lightning-fill"></i> Buy It Now
                        </button>
                        <a asp-page="/Index" class="eb-btn-outline">Continue shopping</a>
                    </form>
                </div>

            </div>
        </div>

        <!-- RIGHT: Seller & shipping sidebar -->
        <div class="col-lg-3">

            <!-- Seller card -->
            <div class="eb-sidebar-card">
                <h6><i class="bi bi-shop me-2 text-eb-blue"></i>Seller information</h6>
                <div class="eb-seller-name">@Model.SellerUsername</div>
                <div class="eb-seller-meta"><i class="bi bi-envelope me-1"></i>@Model.SellerEmail</div>
                <div class="eb-seller-meta"><i class="bi bi-star-fill me-1" style="color:#F5AF02"></i> Top Rated Seller</div>
                <div class="mt-3">
                    <a class="btn btn-sm btn-outline-primary w-100 rounded-pill">
                        <i class="bi bi-shop"></i> View store
                    </a>
                </div>
            </div>

            <!-- Shipping info -->
            <div class="eb-sidebar-card">
                <h6><i class="bi bi-truck me-2 text-eb-blue"></i>Shipping</h6>
                <div class="eb-info-row">
                    <i class="bi bi-box-seam"></i>
                    <span>Calculated at checkout. Estimated delivery <strong>3–7 business days</strong>.</span>
                </div>
                <div class="eb-info-row">
                    <i class="bi bi-geo-alt"></i>
                    <span>Ships within Vietnam.</span>
                </div>
            </div>

            <!-- Returns info -->
            <div class="eb-sidebar-card">
                <h6><i class="bi bi-arrow-return-left me-2 text-eb-blue"></i>Returns</h6>
                <div class="eb-info-row">
                    <i class="bi bi-calendar-check"></i>
                    <span><strong>30-day</strong> return policy. Buyer pays return shipping.</span>
                </div>
                <div class="eb-info-row">
                    <i class="bi bi-shield-check"></i>
                    <span>eBayClone Money Back Guarantee — get the item you ordered or your money back.</span>
                </div>
            </div>

        </div>
    </div>

</div>
