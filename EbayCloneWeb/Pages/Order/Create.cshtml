<script>
    (function () {
        var price = @(Model.Product?.Price ?? 0);
        var fees = { hanoi: 20, mienbac: 30, mientrung: 40, miennam: 50 };
        function update() {
            var qty = parseInt(document.querySelector('input[name="Quantity"]')?.value || 1, 10);
            var region = document.getElementById('regionSelect')?.value || 'hanoi';
            var fee = fees[region] || 50;
            var subtotal = price * qty;
            var total = subtotal + fee;
            var feeEl = document.getElementById('shippingFee');
            var totalEl = document.getElementById('totalEstimate');
            if (feeEl) feeEl.textContent = fee;
            if (totalEl) totalEl.textContent = total + 'k';
        }
        document.getElementById('regionSelect')?.addEventListener('change', update);
        document.querySelector('input[name="Quantity"]')?.addEventListener('input', update);
        document.querySelector('input[name="Quantity"]')?.addEventListener('change', update);
        update();
    })();
</script>
