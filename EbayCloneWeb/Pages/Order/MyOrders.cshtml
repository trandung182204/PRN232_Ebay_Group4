@page
@model EbayCloneWeb.Pages.Order.MyOrdersModel
@{
    ViewData["Title"] = "My Orders";
}

<div class="container-fluid px-4 py-4" style="max-width: 900px; margin: 0 auto;">
    <h1 class="h4 mb-4">
        <i class="bi bi-bag-check me-2"></i>My Orders
    </h1>

    @* Lọc theo trạng thái *@
    <div class="mb-3">
        <form method="get" class="row g-2 align-items-center">
            <div class="col-auto">
                <label class="form-label small mb-0">Status</label>
            </div>
            <div class="col-auto">
                <select name="status" class="form-select form-select-sm" style="width: auto;">
                    <option value="">All</option>
                    <option value="PendingPayment" selected="@(Model.StatusFilter == "PendingPayment")">Pending payment</option>
                    <option value="Paid" selected="@(Model.StatusFilter == "Paid")">Paid</option>
                    <option value="Shipping" selected="@(Model.StatusFilter == "Shipping")">Shipping</option>
                    <option value="Delivered" selected="@(Model.StatusFilter == "Delivered")">Delivered</option>
                    <option value="Cancelled" selected="@(Model.StatusFilter == "Cancelled")">Cancelled</option>
                </select>
            </div>
            <div class="col-auto">
                <button type="submit" class="btn btn-sm btn-outline-secondary">Filter</button>
            </div>
        </form>
    </div>

    @if (Model.Response?.data == null || !Model.Response.data.Any())
    {
        <div class="alert alert-light border text-muted text-center py-5">
            <i class="bi bi-inbox" style="font-size: 2.5rem;"></i>
            <p class="mt-2 mb-0">You don't have any orders yet.</p>
            <a asp-page="/Index" class="btn btn-primary btn-sm mt-2">Shop now</a>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Order #</th>
                        <th>Order date</th>
                        <th>Status</th>
                        <th class="text-end">Total</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var o in Model.Response.data)
                    {
                        var statusStr = o.Status?.ToString() ?? "—";
                        var statusBadge = statusStr switch
                        {
                            "PendingPayment" => "bg-warning text-dark",
                            "Paid" => "bg-info",
                            "Shipping" => "bg-primary",
                            "Delivered" => "bg-success",
                            "Cancelled" or "Failed" => "bg-secondary",
                            _ => "bg-secondary"
                        };
                        <tr>
                            <td class="fw-semibold">#@o.Id</td>
                            <td>@(o.OrderDate?.ToString("dd/MM/yyyy HH:mm") ?? "—")</td>
                            <td><span class="badge @statusBadge">@statusStr</span></td>
                            <td class="text-end fw-semibold text-danger">US $@o.TotalPrice.ToString("0.00")</td>
                            <td class="text-end">
                                <a asp-page="/Order/Success" asp-route-id="@o.Id" class="btn btn-sm btn-outline-primary">
                                    View order &amp; tracking number
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (Model.Response.total > Model.Response.pageSize)
        {
            <nav class="mt-3">
                <ul class="pagination pagination-sm justify-content-center">
                    @if (Model.Response.page > 1)
                    {
                        <li class="page-item">
                            <a class="page-link" asp-route-page="@(Model.Response.page - 1)" asp-route-status="@Model.StatusFilter">Previous</a>
                        </li>
                    }
                    <li class="page-item disabled">
                        <span class="page-link">Page @Model.Response.page / @((Model.Response.total + Model.Response.pageSize - 1) / Model.Response.pageSize)</span>
                    </li>
                    @if (Model.Response.page * Model.Response.pageSize < Model.Response.total)
                    {
                        <li class="page-item">
                            <a class="page-link" asp-route-page="@(Model.Response.page + 1)" asp-route-status="@Model.StatusFilter">Next</a>
                        </li>
                    }
                </ul>
            </nav>
        }
    }
</div>
