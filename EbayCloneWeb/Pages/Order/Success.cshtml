@page
@model EbayCloneWeb.Pages.Order.SuccessModel
@{
    ViewData["Title"] = "Order placed";
}

<div class="container py-5" style="max-width: 640px; margin: 0 auto;">
    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-warning">
            <i class="bi bi-exclamation-triangle me-2"></i>@Model.ErrorMessage
        </div>
        <a asp-page="/Index" class="btn btn-primary">Back to home</a>
        return;
    }

    @if (Model.Order != null)
    {
        <div class="text-center mb-4">
            <div class="text-success mb-2" style="font-size: 3rem;"><i class="bi bi-check-circle-fill"></i></div>
            <h1 class="h4">Order placed successfully</h1>
            <p class="text-muted mb-0">Order #@Model.Order.Id</p>
        </div>

        <div class="card shadow-sm border-0 rounded-3 overflow-hidden">
            <div class="card-body p-4">
                <div class="row mb-3">
                    <div class="col text-muted">Date</div>
                    <div class="col text-end">@Model.Order.OrderDate.ToString("yyyy-MM-dd HH:mm")</div>
                </div>
                <div class="row mb-3">
                    <div class="col text-muted">Status</div>
                    <div class="col text-end"><span class="badge bg-secondary">@(Model.Order.Status ?? "—")</span></div>
                </div>
                <div class="row mb-3">
                    <div class="col text-muted">Total</div>
                    <div class="col text-end fw-bold text-danger">US $@Model.Order.TotalPrice.ToString("0.00")</div>
                </div>

                @if (Model.Order.ShippingInfos != null && Model.Order.ShippingInfos.Count > 0)
                {
                    <hr class="my-3" />
                    <h6 class="mb-2"><i class="bi bi-truck me-2"></i>Tracking number (Shipment tracking)</h6>
                    <p class="small text-muted mb-2">Use the tracking number below to track your shipment at the <strong>Track order</strong> page in the menu.</p>
                    <ul class="list-group list-group-flush">
                        @foreach (var s in Model.Order.ShippingInfos)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                                <code class="bg-light px-2 py-1 rounded">@s.TrackingNumber</code>
                                <span class="badge bg-secondary">@(s.Status ?? "Pending")</span>
                            </li>
                        }
                    </ul>
                    <div class="mt-3">
                        <a asp-page="/Tracking/Index" asp-route-code="@Model.Order.ShippingInfos.First().TrackingNumber" class="btn btn-outline-primary btn-sm">
                            <i class="bi bi-search me-1"></i>Track shipment
                        </a>
                    </div>
                }
                else
                {
                    <p class="small text-muted mb-0">A tracking number will be generated after successful payment (PayPal order) or is available right away for COD orders.</p>
                }
            </div>
        </div>

        <div class="text-center mt-4">
            <a asp-page="/Index" class="btn btn-primary">Continue shopping</a>
        </div>
    }
</div>
