<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - eBayClone</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/custom.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/EbayCloneWeb.styles.css" asp-append-version="true" />
</head>
<body>

<header>
    <nav class="eb-navbar">
        <div class="eb-navbar-inner">

            <!-- Logo -->
            <a class="eb-logo" asp-page="/Index">
                <span class="eb-e">e</span><span class="eb-b">b</span><span class="eb-a">a</span><span class="eb-y">y</span><span class="eb-clone">Clone</span>
            </a>

            <!-- Search bar — submits GET to /Index; JS syncs heroQ <-> q on Index page -->
            <form class="eb-search-wrap" action="/" method="get">
                <div class="eb-search-group">
                    <select name="categoryId" id="navCatId" class="eb-search-cat">
                        <option value="">All Categories</option>
                    </select>
                    <input type="text" name="q" id="heroQ" class="eb-search-input" placeholder="Search for anything" autocomplete="off" />
                    <button type="submit" class="eb-search-btn">
                        <i class="bi bi-search"></i> Search
                    </button>
                </div>
            </form>

            <!-- User actions -->
            <div class="eb-nav-actions">

                @if (Context.Session.GetInt32("UserId") != null)
                {
                    <span class="eb-nav-user">
                        <i class="bi bi-person-circle"></i>
                        Hi, <strong>@Context.Session.GetString("Role")</strong>
                    </span>

                    @if (Context.Session.GetString("Role")?.ToLower() == "admin")
                    {
                        <a class="eb-nav-link eb-nav-admin" asp-page="/Admin/Orders/Index">
                            <i class="bi bi-box-seam"></i> Orders
                        </a>
                    }

                    <form method="post" asp-page="/Account/Logout" style="display:inline;margin:0;padding:0">
                        <button type="submit" class="eb-logout-btn">
                            <i class="bi bi-box-arrow-right"></i> Logout
                        </button>
                    </form>
                }
                else
                {
                    <a class="eb-signin-btn" asp-page="/Account/Login">Sign in</a>
                }

            </div>
        </div>
    </nav>
</header>

<!-- Category navigation strip -->
<div class="eb-cat-strip">
    <div class="eb-cat-strip-inner" id="ebCatStrip">
        <a class="eb-cat-link" href="/">All</a>
        <!-- populated by site.js -->
    </div>
</div>

@if (TempData["Success"] != null || TempData["Error"] != null)
{
    <div class="container mt-3">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show">
                <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
                <button class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show">
                <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
                <button class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
    </div>
}

<main role="main" class="pb-4">
    @RenderBody()
</main>

<footer class="eb-footer">
    <div class="container">
        <div class="row">
            <div class="col-md-3 mb-4">
                <a class="eb-footer-logo" asp-page="/Index">
                    <span class="eb-e">e</span><span class="eb-b">b</span><span class="eb-a">a</span><span class="eb-y">y</span><span style="color:#888;font-size:0.85rem;font-weight:400;font-style:normal;">Clone</span>
                </a>
                <p style="color:#888;font-size:13px;margin-top:6px;">An eBay-inspired e-commerce platform.</p>
            </div>
            <div class="col-md-3 mb-4">
                <h6>Buy</h6>
                <a asp-page="/Index">Browse products</a>
                <a asp-page="/Account/Login">My account</a>
            </div>
            <div class="col-md-3 mb-4">
                <h6>Help &amp; Contact</h6>
                <a asp-page="/Privacy">Privacy Policy</a>
                <a href="#">Help Center</a>
            </div>
            <div class="col-md-3 mb-4">
                <h6>About eBayClone</h6>
                <a href="#">About Us</a>
                <a href="#">PRN232 – Group 4</a>
            </div>
        </div>
        <div class="eb-footer-bottom">
            <span>Copyright &copy; 2026 eBayClone — PRN232 Group 4. All rights reserved.</span>
        </div>
    </div>
</footer>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js"></script>

@await RenderSectionAsync("Scripts", required: false)

</body>
</html>
