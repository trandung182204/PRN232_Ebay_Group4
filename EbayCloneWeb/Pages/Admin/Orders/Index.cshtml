@page
@model EbayCloneWeb.Pages.Admin.Orders.IndexModel
@{
    ViewData["Title"] = "Order Management";
}

<div class="container-fluid px-4 py-4" style="max-width:1400px;margin:0 auto;">

    <div class="eb-admin-header">
        <div class="eb-admin-title">
            <i class="bi bi-list-check text-eb-blue"></i>
            Order Management
        </div>
    </div>

    <!-- Filter -->
    <div class="eb-admin-card mb-4">
        <div class="eb-admin-card-header">
            <i class="bi bi-funnel me-2"></i>Filter orders
        </div>
        <div class="eb-admin-card-body">
            <form method="get" class="d-flex flex-wrap gap-2 align-items-center">
                <input type="hidden" name="page" value="1" />
                <select name="status" class="form-select form-select-sm" style="width:auto;min-width:180px;">
                    <option value="">All Statuses</option>
                    <option value="PendingPayment" selected="@(Request.Query["status"] == "PendingPayment")">PendingPayment</option>
                    <option value="Paid" selected="@(Request.Query["status"] == "Paid")">Paid</option>
                    <option value="Shipping" selected="@(Request.Query["status"] == "Shipping")">Shipping</option>
                    <option value="Delivered" selected="@(Request.Query["status"] == "Delivered")">Delivered</option>
                    <option value="Cancelled" selected="@(Request.Query["status"] == "Cancelled")">Cancelled</option>
                </select>
                <button class="btn btn-sm btn-primary rounded-pill px-3">
                    <i class="bi bi-funnel"></i> Apply filter
                </button>
            </form>
            <p class="mb-0 small text-muted mt-2">Hiển thị tất cả đơn hàng (không lọc theo user). Tổng: <strong>@Model.TotalCount</strong> đơn.</p>
        </div>
    </div>

    <!-- Table -->
    <div class="eb-admin-card">
        <div class="eb-admin-card-body p-0">
            <div class="table-responsive">
                <table class="eb-table">
                    <thead>
                        <tr>
                            <th>Order ID</th>
                            <th>Date</th>
                            <th>Total</th>
                            <th>Status</th>
                            <th>Tracking</th>
                            <th style="width:220px;">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var o in Model.Orders)
                        {
                            <tr>
                                <td>
                                    <a asp-page="/Admin/Orders/Detail" asp-route-id="@o.Id"
                                       class="fw-bold text-decoration-none text-eb-blue">
                                        #@o.Id
                                    </a>
                                </td>
                                <td class="text-muted">
                                    @o.OrderDate.ToString("yyyy-MM-dd HH:mm")
                                </td>
                                <td>
                                    <span class="fw-bold" style="color:var(--eb-red)">
                                        US $@o.TotalPrice
                                    </span>
                                </td>
                                <td>
                                    @if (o.Status == "PendingPayment")
                                    {
                                        <span class="eb-badge eb-badge-pending">Pending</span>
                                    }
                                    else if (o.Status == "Paid")
                                    {
                                        <span class="eb-badge eb-badge-paid">Paid</span>
                                    }
                                    else if (o.Status == "Shipping")
                                    {
                                        <span class="eb-badge eb-badge-shipping">Shipping</span>
                                    }
                                    else if (o.Status == "Delivered")
                                    {
                                        <span class="eb-badge eb-badge-done">Delivered</span>
                                    }
                                    else
                                    {
                                        <span class="eb-badge eb-badge-cancel">Cancelled</span>
                                    }
                                </td>
                                <td>
                                    @if (o.TrackingNumbers != null && o.TrackingNumbers.Count > 0)
                                    {
                                        @foreach (var code in o.TrackingNumbers)
                                        {
                                            <a asp-page="/Tracking/Index" asp-route-code="@code" target="_blank" class="d-block small text-eb-blue text-decoration-none" title="Tra cứu vận đơn">@code</a>
                                        }
                                    }
                                    else
                                    {
                                        <span class="text-muted small">—</span>
                                    }
                                </td>
                                <td>
                                    <select class="form-select form-select-sm rounded-pill"
                                            onchange="updateStatus(@o.Id, this.value)">
                                        @if (o.Status == "PendingPayment")
                                        {
                                            <option value="">Select action</option>
                                            <option value="Paid">Mark as Paid</option>
                                            <option value="Cancelled">Cancel order</option>
                                            <option value="Failed">Mark as Failed</option>
                                        }
                                        else if (o.Status == "Paid")
                                        {
                                            <option value="">Select action</option>
                                            <option value="Shipping">Ship order</option>
                                            <option value="Cancelled">Cancel order</option>
                                        }
                                        else if (o.Status == "Shipping")
                                        {
                                            <option value="">Select action</option>
                                            <option value="Delivered">Mark delivered</option>
                                        }
                                        else
                                        {
                                            <option selected disabled>No actions</option>
                                        }
                                    </select>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            @if (Model.TotalCount > Model.PageSize)
            {
                <div class="d-flex justify-content-between align-items-center p-3 border-top">
                    <span class="small text-muted">Trang @Model.Page / @((Model.TotalCount + Model.PageSize - 1) / Model.PageSize)</span>
                    <nav>
                        @if (Model.Page > 1)
                        {
                            <a class="btn btn-sm btn-outline-secondary me-1" asp-route-status="@Request.Query["status"]" asp-route-page="@(Model.Page - 1)" asp-route-pageSize="@Model.PageSize">Trước</a>
                        }
                        @if (Model.Page * Model.PageSize < Model.TotalCount)
                        {
                            <a class="btn btn-sm btn-outline-secondary" asp-route-status="@Request.Query["status"]" asp-route-page="@(Model.Page + 1)" asp-route-pageSize="@Model.PageSize">Sau</a>
                        }
                    </nav>
                </div>
            }
        </div>
    </div>

</div>


<script>

    async function updateStatus(id, status) {
        if (!status) return;

        const confirmChange = confirm("Change order status to " + status + "?");

        if (!confirmChange) {
            location.reload();
            return;
        }

        const res = await fetch(`http://localhost:5174/api/order/${id}/status`,
            {
                method: 'PUT',
                headers:
                {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify(status)
            });

        if (res.ok) {
            alert("Status updated successfully");
            location.reload();
        }
        else {
            const text = await res.text();
            alert("Update failed: " + text);
            location.reload();
        }
    }

</script>