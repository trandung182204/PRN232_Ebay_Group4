@page
@model EbayCloneWeb.Pages.Admin.Orders.IndexModel
@{
    ViewData["Title"] = "Order Management";
}

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">
            <i class="bi bi-list-check text-primary"></i>
            Order Management
        </h2>
    </div>

    <!-- Filter -->
    <div class="card shadow-sm mb-4">
        <div class="card-body">

            <form method="get" class="row g-2 align-items-center">

                <div class="col-md-4">
                    <select name="status" class="form-select">
                        <option value="">All Status</option>
                        <option>PendingPayment</option>
                        <option>Paid</option>
                        <option>Shipping</option>
                        <option>Delivered</option>
                        <option>Cancelled</option>
                    </select>
                </div>

                <div class="col-md-2">
                    <button class="btn btn-primary w-100">
                        <i class="bi bi-funnel"></i> Filter
                    </button>
                </div>

            </form>

        </div>
    </div>

    <!-- Table -->
    <div class="card shadow-sm">
        <div class="card-body">

            <div class="table-responsive">

                <table class="table table-hover align-middle">

                    <thead class="table-dark">
                        <tr>
                            <th>OrderId</th>
                            <th>Date</th>
                            <th>Total</th>
                            <th>Status</th>
                            <th width="320">Action</th>
                        </tr>
                    </thead>

                    <tbody>

                        @foreach (var o in Model.Orders)
                        {
                            <tr>

                                <td>
                                    <span class="fw-bold">#@o.Id</span>
                                </td>

                                <td>
                                    @o.OrderDate.ToString("yyyy-MM-dd HH:mm")
                                </td>

                                <td>
                                    <span class="text-danger fw-bold">
                                        $@o.TotalPrice
                                    </span>
                                </td>

                                <td>

                                    @if (o.Status == "PendingPayment")
                                    {
                                        <span class="badge bg-warning text-dark">Pending</span>
                                    }
                                    else if (o.Status == "Paid")
                                    {
                                        <span class="badge bg-info text-dark">Paid</span>
                                    }
                                    else if (o.Status == "Shipping")
                                    {
                                        <span class="badge bg-primary">Shipping</span>
                                    }
                                    else if (o.Status == "Delivered")
                                    {
                                        <span class="badge bg-success">Delivered</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Cancelled</span>
                                    }

                                </td>

                                <td>

                                    @if (o.Status == "PendingPayment")
                                    {
                                        <button class="btn btn-sm btn-success me-1"
                                                onclick="updateStatus(@o.Id,'Paid')">
                                            Confirm Payment
                                        </button>
                                    }

                                    @if (o.Status == "Paid")
                                    {
                                        <button class="btn btn-sm btn-primary me-1"
                                                onclick="updateStatus(@o.Id,'Shipping')">
                                            Ship
                                        </button>
                                    }

                                    @if (o.Status == "Shipping")
                                    {
                                        <button class="btn btn-sm btn-info me-1"
                                                onclick="updateStatus(@o.Id,'Delivered')">
                                            Deliver
                                        </button>
                                    }

                                    <button class="btn btn-sm btn-danger"
                                            onclick="updateStatus(@o.Id,'Cancelled')">
                                        Cancel
                                    </button>

                                </td>

                            </tr>
                        }

                    </tbody>

                </table>

            </div>

        </div>
    </div>

</div>

<script>

async function updateStatus(id, status) {

    await fetch(`http://localhost:5174/api/order/${id}/status`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(status)
    });

    location.reload();
}

</script>