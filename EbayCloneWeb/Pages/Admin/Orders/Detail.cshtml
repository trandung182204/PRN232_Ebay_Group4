@page "{id:int}"
@model EbayCloneWeb.Pages.Admin.Orders.DetailModel
@{
    ViewData["Title"] = "Order Detail";
}

<div class="container mt-4">

    <h2 class="mb-4">
        <i class="bi bi-receipt"></i>
        Order Detail #@Model.Order?.Id
    </h2>

    @if (Model.Order == null)
    {
        <div class="alert alert-danger">
            Order not found
        </div>
    }
    else
    {

        <!-- ORDER INFO -->

        <div class="card mb-4 shadow-sm">
            <div class="card-header fw-bold">
                Order Information
            </div>

            <div class="card-body">

                <div class="row">

                    <div class="col-md-4">
                        <b>Order Id</b>
                        <div>#@Model.Order.Id</div>
                    </div>

                    <div class="col-md-4">
                        <b>Date</b>
                        <div>@Model.Order.OrderDate</div>
                    </div>

                    <div class="col-md-4">
                        <b>Status</b>
                        <div>@Model.Order.Status</div>
                    </div>

                </div>

                <div class="mt-3">
                    <b>Total</b>
                    <div class="text-danger fw-bold">
                        $@Model.Order.TotalPrice
                    </div>
                </div>

            </div>
        </div>


        <!-- ORDER ITEMS -->

        <div class="card shadow-sm mb-4">

            <div class="card-header fw-bold">
                Order Items
            </div>

            <div class="card-body">

                <table class="table table-bordered">

                    <thead>
                        <tr>
                            <th>Product</th>
                            <th>Price</th>
                            <th>Quantity</th>
                            <th>Total</th>
                        </tr>
                    </thead>

                    <tbody>

                        @foreach (var item in Model.Order.OrderItems)
                        {
                            <tr>

                                <td>
                                    @item.Product?.Name
                                </td>

                                <td>
                                    $@item.Product?.Price
                                </td>

                                <td>
                                    @item.Quantity
                                </td>

                                <td>
                                    $@(item.Quantity * (item.Product?.Price ?? 0))
                                </td>

                            </tr>
                        }

                    </tbody>

                </table>

            </div>

        </div>


        <!-- PAYMENT -->

        <div class="card shadow-sm mb-4">

            <div class="card-header fw-bold">
                Payment
            </div>

            <div class="card-body">

                @foreach (var p in Model.Order.Payments)
                {
                    <div>
                        Method: <b>@p.Method</b>
                    </div>

                    <div>
                        Amount: $@p.Amount
                    </div>

                    <div>
                        Paid At: @p.PaidAt
                    </div>
                }

            </div>

        </div>


        <!-- SHIPPING -->

        <div class="card shadow-sm">

            <div class="card-header fw-bold">
                Shipping
            </div>

            <div class="card-body">

                @foreach (var s in Model.Order.ShippingInfos)
                {
                    <div>
                        Tracking: <b>@s.TrackingNumber</b>
                    </div>

                    <div>
                        Status: @s.Status
                    </div>
                }

            </div>

        </div>

    }

</div>