@page "{id:int}"
@model EbayCloneWeb.Pages.Admin.Orders.DetailModel
@{
    ViewData["Title"] = "Order Detail";
}

<div class="container-fluid px-4 py-4" style="max-width:1100px;margin:0 auto;">

    <div class="eb-admin-header">
        <div class="eb-admin-title">
            <i class="bi bi-receipt text-eb-blue"></i>
            Order Detail #@Model.Order?.Id
        </div>
        <a asp-page="/Admin/Orders/Index" class="btn btn-sm btn-outline-secondary rounded-pill">
            <i class="bi bi-arrow-left me-1"></i>Back to orders
        </a>
    </div>

    @if (Model.Order == null)
    {
        <div class="alert alert-danger rounded-3">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>Order not found.
        </div>
    }
    else
    {
        <!-- ORDER INFO -->
        <div class="eb-admin-card mb-4">
            <div class="eb-admin-card-header">
                <i class="bi bi-info-circle me-2"></i>Order Information
            </div>
            <div class="eb-admin-card-body">
                <div class="row g-3">
                    <div class="col-sm-3">
                        <div class="text-muted small">Order ID</div>
                        <div class="fw-bold">#@Model.Order.Id</div>
                    </div>
                    <div class="col-sm-3">
                        <div class="text-muted small">Date</div>
                        <div>@Model.Order.OrderDate.ToString("yyyy-MM-dd HH:mm")</div>
                    </div>
                    <div class="col-sm-3">
                        <div class="text-muted small">Status</div>
                        <div>
                            @if (Model.Order.Status == "PendingPayment")      { <span class="eb-badge eb-badge-pending">Pending</span> }
                            else if (Model.Order.Status == "Paid")            { <span class="eb-badge eb-badge-paid">Paid</span> }
                            else if (Model.Order.Status == "Shipping")        { <span class="eb-badge eb-badge-shipping">Shipping</span> }
                            else if (Model.Order.Status == "Delivered")       { <span class="eb-badge eb-badge-done">Delivered</span> }
                            else                                               { <span class="eb-badge eb-badge-cancel">@Model.Order.Status</span> }
                        </div>
                    </div>
                    <div class="col-sm-3">
                        <div class="text-muted small">Total</div>
                        <div class="fw-bold fs-5" style="color:var(--eb-red)">US $@Model.Order.TotalPrice</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- ORDER ITEMS -->
        <div class="eb-admin-card mb-4">
            <div class="eb-admin-card-header">
                <i class="bi bi-bag me-2"></i>Order Items
            </div>
            <div class="p-0">
                <table class="eb-table">
                    <thead>
                        <tr>
                            <th>Product</th>
                            <th>Unit Price</th>
                            <th>Qty</th>
                            <th>Line Total</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Order.OrderItems)
                        {
                            <tr>
                                <td class="fw-semibold">@item.Product?.Title</td>
                                <td>US $@item.Product?.Price</td>
                                <td>@item.Quantity</td>
                                <td class="fw-bold" style="color:var(--eb-red)">
                                    US $@(item.Quantity * (item.Product?.Price ?? 0))
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- PAYMENT -->
        <div class="eb-admin-card mb-4">
            <div class="eb-admin-card-header">
                <i class="bi bi-credit-card me-2"></i>Payment
            </div>
            <div class="eb-admin-card-body">
                @foreach (var p in Model.Order.Payments)
                {
                    <div class="row g-2">
                        <div class="col-sm-4">
                            <div class="text-muted small">Method</div>
                            <div class="fw-semibold">@p.Method</div>
                        </div>
                        <div class="col-sm-4">
                            <div class="text-muted small">Amount</div>
                            <div class="fw-semibold">US $@p.Amount</div>
                        </div>
                        <div class="col-sm-4">
                            <div class="text-muted small">Paid At</div>
                            <div>@(p.PaidAt?.ToString("yyyy-MM-dd HH:mm") ?? "-")</div>
                        </div>
                    </div>
                }
            </div>
        </div>

        <!-- SHIPPING (admin có thể cập nhật trạng thái ship) -->
        <div class="eb-admin-card">
            <div class="eb-admin-card-header">
                <i class="bi bi-truck me-2"></i>Shipping
            </div>
            <div class="eb-admin-card-body">
                @if (Model.Order.ShippingInfos == null || !Model.Order.ShippingInfos.Any())
                {
                    <p class="text-muted mb-0">Chưa có thông tin vận chuyển.</p>
                }
                else
                {
                    @foreach (var s in Model.Order.ShippingInfos)
                    {
                        <div class="row g-2 align-items-end mb-3 pb-3 border-bottom">
                            <div class="col-sm-4">
                                <div class="text-muted small">Tracking number</div>
                                <div class="fw-semibold">@s.TrackingNumber</div>
                            </div>
                            <div class="col-sm-4">
                                <div class="text-muted small">Trạng thái vận chuyển</div>
                                <select class="form-select form-select-sm ship-status-select" data-tracking="@s.TrackingNumber" onchange="updateShipStatus(this)">
                                    <option value="Pending" selected="@(s.Status == "Pending")">Pending</option>
                                    <option value="InTransit" selected="@(s.Status == "InTransit")">InTransit</option>
                                    <option value="Delivered" selected="@(s.Status == "Delivered")">Delivered</option>
                                </select>
                            </div>
                            <div class="col-sm-4">
                                <a asp-page="/Tracking/Index" asp-route-code="@s.TrackingNumber" target="_blank" class="btn btn-sm btn-outline-primary">Tra cứu</a>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    }

</div>

@section Scripts {
<script>
async function updateShipStatus(selectEl) {
    var code = selectEl.dataset.tracking;
    var status = selectEl.value;
    if (!code || !status) return;
    try {
        var res = await fetch('http://localhost:5174/api/Tracking/' + encodeURIComponent(code) + '/status', {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ status: status })
        });
        if (res.ok)
            alert('Đã cập nhật trạng thái vận chuyển.');
        else
            alert('Cập nhật thất bại: ' + (await res.text()));
    } catch (e) {
        alert('Lỗi: ' + e.message);
    }
}
</script>
}