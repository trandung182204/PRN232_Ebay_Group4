@page
@model IndexModel
@{
    ViewData["Title"] = "Home";
}

<div class="container-fluid px-4 pt-4" style="max-width:1400px;margin:0 auto;">

    <!-- ====================================================
         PROMOTIONAL BANNER — Slideable Carousel
    ==================================================== -->
    <div id="heroBannerCarousel" class="carousel slide eb-hero-carousel" data-bs-ride="carousel" data-bs-interval="5000">

        <!-- Dot indicators -->
        <div class="carousel-indicators">
            <button type="button" data-bs-target="#heroBannerCarousel" data-bs-slide-to="0" class="active" aria-current="true"></button>
            <button type="button" data-bs-target="#heroBannerCarousel" data-bs-slide-to="1"></button>
            <button type="button" data-bs-target="#heroBannerCarousel" data-bs-slide-to="2"></button>
        </div>

        <div class="carousel-inner">

            <!-- ── Slide 1: Luxury & Fashion (Purple) ── -->
            <div class="carousel-item active">
                <div class="eb-hero-banner eb-slide-purple">
                    <div class="eb-hero-text">
                        <div class="eb-hero-title">Good taste is timeless</div>
                        <div class="eb-hero-sub">Create iconic looks with exclusive deals on luxury watches, jewellery &amp; bags.</div>
                        <a href="#productGridRow" class="eb-hero-cta">Explore now</a>
                    </div>
                    <div class="eb-hero-images">
                        <div class="eb-hero-img-card"><i class="bi bi-smartwatch"></i></div>
                        <div class="eb-hero-img-card"><i class="bi bi-gem"></i></div>
                        <div class="eb-hero-img-card"><i class="bi bi-handbag-fill"></i></div>
                        <div class="eb-hero-img-card"><i class="bi bi-bag-heart-fill"></i></div>
                    </div>
                    <div class="eb-hero-badge">
                        <div class="eb-hero-badge-label">Up to</div>
                        <div class="eb-hero-badge-amount">$140<sup>*</sup></div>
                        <div class="eb-hero-badge-off">OFF</div>
                    </div>
                </div>
            </div>

            <!-- ── Slide 2: Tech & Electronics (Blue) ── -->
            <div class="carousel-item">
                <div class="eb-hero-banner eb-slide-blue">
                    <div class="eb-hero-text">
                        <div class="eb-hero-title">Technology at your fingertips</div>
                        <div class="eb-hero-sub">Top deals on laptops, phones, headphones and the latest gadgets.</div>
                        <a href="#productGridRow" class="eb-hero-cta">Shop Tech</a>
                    </div>
                    <div class="eb-hero-images">
                        <div class="eb-hero-img-card"><i class="bi bi-laptop"></i></div>
                        <div class="eb-hero-img-card"><i class="bi bi-phone-fill"></i></div>
                        <div class="eb-hero-img-card"><i class="bi bi-headphones"></i></div>
                        <div class="eb-hero-img-card"><i class="bi bi-controller"></i></div>
                    </div>
                    <div class="eb-hero-badge">
                        <div class="eb-hero-badge-label">Up to</div>
                        <div class="eb-hero-badge-amount">$80<sup>*</sup></div>
                        <div class="eb-hero-badge-off">OFF</div>
                    </div>
                </div>
            </div>

            <!-- ── Slide 3: Home & Living (Teal) ── -->
            <div class="carousel-item">
                <div class="eb-hero-banner eb-slide-teal">
                    <div class="eb-hero-text">
                        <div class="eb-hero-title">Home &amp; Living essentials</div>
                        <div class="eb-hero-sub">Everything you need to make your home more beautiful and comfortable.</div>
                        <a href="#productGridRow" class="eb-hero-cta">Shop Home</a>
                    </div>
                    <div class="eb-hero-images">
                        <div class="eb-hero-img-card"><i class="bi bi-house-heart-fill"></i></div>
                        <div class="eb-hero-img-card"><i class="bi bi-lamp-fill"></i></div>
                        <div class="eb-hero-img-card"><i class="bi bi-flower1"></i></div>
                        <div class="eb-hero-img-card"><i class="bi bi-cup-hot-fill"></i></div>
                    </div>
                    <div class="eb-hero-badge">
                        <div class="eb-hero-badge-label">Up to</div>
                        <div class="eb-hero-badge-amount">$60<sup>*</sup></div>
                        <div class="eb-hero-badge-off">OFF</div>
                    </div>
                </div>
            </div>

        </div><!-- /carousel-inner -->

        <!-- Prev / Next arrows (appear on hover) -->
        <button class="carousel-control-prev" type="button" data-bs-target="#heroBannerCarousel" data-bs-slide="prev">
            <span class="carousel-control-prev-icon" aria-hidden="true"></span>
            <span class="visually-hidden">Previous</span>
        </button>
        <button class="carousel-control-next" type="button" data-bs-target="#heroBannerCarousel" data-bs-slide="next">
            <span class="carousel-control-next-icon" aria-hidden="true"></span>
            <span class="visually-hidden">Next</span>
        </button>

    </div><!-- /heroBannerCarousel -->

    <!-- ====================================================
         FILTER / SORT BAR
    ==================================================== -->
    <form id="filterForm" method="get">
        <!-- Hidden inputs — values set by navbar search + JS -->
        <input type="hidden" id="q"          name="q"          value="@Model.Q" />
        <input type="hidden" id="categoryId" name="categoryId" />
        <input type="hidden" id="orderBy"    name="orderBy" />
        <input type="hidden" id="sortDir"    name="sortDir" />

        <div class="eb-filter-bar">

            <span class="eb-filter-label">Sort:</span>

            <!-- Combined sort select — fixes the separate Low/High confusion -->
            <select id="sortSelect" class="eb-filter-select">
                <option value="">Best Match</option>
                <option value="price_asc">Price: Low to High</option>
                <option value="price_desc">Price: High to Low</option>
                <option value="title_asc">Title: A → Z</option>
                <option value="title_desc">Title: Z → A</option>
            </select>

            <div class="eb-filter-divider"></div>

            <span class="eb-filter-label">Items per page:</span>

            <select id="pageSize" name="pageSize" class="eb-filter-select" style="min-width:90px;">
                <option value="8">8</option>
                <option value="16" selected>16</option>
                <option value="32">32</option>
                <option value="48">48</option>
            </select>

            <button type="button" id="clearFilters" class="eb-clear-btn ms-auto">
                <i class="bi bi-x-circle me-1"></i>Clear
            </button>
        </div>
    </form>

    <!-- ====================================================
         SECTION HEADER
    ==================================================== -->
    <div class="eb-section-header mb-3">
        <span class="eb-section-title">
            @if (!string.IsNullOrEmpty(Model.Q))
            {
                <text>Results for "<em>@Model.Q</em>"</text>
            }
            else
            {
                <text>All listings</text>
            }
        </span>
        <span class="eb-results-count">@Model.TotalItems results</span>
    </div>

    <!-- ====================================================
         PRODUCT GRID
    ==================================================== -->
    <div id="productGridRow" class="row g-3">
        @foreach (var p in Model.Products)
        {
            var img = "/images/placeholder.png";
            if (p.ValueKind == System.Text.Json.JsonValueKind.Object && p.TryGetProperty("images", out var imagesProp))
            {
                if (imagesProp.ValueKind == System.Text.Json.JsonValueKind.String)
                    img = imagesProp.GetString() ?? img;
                else if (imagesProp.ValueKind == System.Text.Json.JsonValueKind.Array && imagesProp.GetArrayLength() > 0)
                {
                    var first = imagesProp[0];
                    if (first.ValueKind == System.Text.Json.JsonValueKind.String)
                        img = first.GetString() ?? img;
                }
            }

            var title = p.TryGetProperty("title", out var t)  && t.ValueKind  == System.Text.Json.JsonValueKind.String ? t.GetString() : "";
            var price = p.TryGetProperty("price", out var pr) && pr.ValueKind == System.Text.Json.JsonValueKind.Number  ? pr.GetDecimal() : 0;
            var id    = p.TryGetProperty("id",    out var pid) && pid.ValueKind == System.Text.Json.JsonValueKind.Number ? pid.GetInt32() : 0;

            string sellerLine = "unknown";
            if (p.ValueKind == System.Text.Json.JsonValueKind.Object)
            {
                if (p.TryGetProperty("seller", out var sellerProp) && sellerProp.ValueKind == System.Text.Json.JsonValueKind.Object)
                {
                    if (sellerProp.TryGetProperty("username", out var sun) && sun.ValueKind == System.Text.Json.JsonValueKind.String)
                        sellerLine = sun.GetString() ?? sellerLine;
                    else if (sellerProp.TryGetProperty("email", out var sem) && sem.ValueKind == System.Text.Json.JsonValueKind.String)
                        sellerLine = sem.GetString() ?? sellerLine;
                }
            }

            <div class="col-xl-2 col-lg-3 col-md-4 col-sm-6">
                <div class="eb-card">
                    <div class="eb-card-img-wrap">
                        <img src="@img" alt="@title" loading="lazy" />
                    </div>
                    <div class="eb-card-body">
                        <div class="eb-card-title">@title</div>
                        <div class="eb-card-price">US $@string.Format("{0:0.00}", price)</div>
                        <div class="eb-card-price-alt">or Best Offer</div>
                        <div class="eb-card-shipping"><i class="bi bi-truck"></i> Free shipping</div>
                        <div class="eb-card-seller"><i class="bi bi-person-fill"></i> @sellerLine</div>
                        <a class="eb-btn-buy" asp-page="/Order/Create" asp-route-id="@id">
                            <i class="bi bi-cart-fill"></i> Buy It Now
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- ====================================================
         PAGINATION
    ==================================================== -->
    <div class="d-flex justify-content-center mt-5 pb-4">
        <nav>
            <ul id="pagination" class="pagination eb-pagination">
                @{
                    var totalPages = (int)System.Math.Ceiling(Model.TotalItems / (double)Model.PageSize);
                }
                @for (int i = 1; i <= totalPages; i++)
                {
                    var css = i == Model.Page ? "active" : "";
                    <li class="page-item @css">
                        <a class="page-link" href="#" data-page="@i">@i</a>
                    </li>
                }
            </ul>
        </nav>
    </div>

</div>
